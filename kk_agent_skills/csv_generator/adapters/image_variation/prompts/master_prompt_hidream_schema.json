{
  "description": "HiDream — VARIATION/STORYLINE mode, 6 camera directions, CJK prompts",
  "_display_field": "t2i_prompt1",

  "_input_schema": {
    "fields": [
      {
        "name": "images",
        "type": "file",
        "accept": "image/*",
        "multiple": true,
        "required": true,
        "label": "Upload Images"
      },
      {
        "name": "num_rows",
        "type": "number",
        "default": 6,
        "min": 3,
        "max": 6,
        "required": false,
        "label": "Variations per Image"
      }
    ],
    "hide_text_input": true,
    "submit_label": "Generate CSV"
  },

  "_filename_field": "subject",
  "_array_field":    "variations",

  "_csv_columns": [
    { "header": "image_filename",  "field": "image_filename" },
    { "header": "t2i_prompt1",     "field": "t2i_prompt1" },
    { "header": "t2i_prompt2",     "field": "t2i_prompt2" },
    { "header": "negative_prompt", "field": "negative_prompt" }
  ],

  "type": "object",
  "required": ["mode", "subject", "variations"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["VARIATION", "STORYLINE"]
    },
    "subject": {
      "type": "string",
      "description": "lowercase, underscore separated, max 3 words"
    },
    "variations": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["image_filename", "camera_direction", "t2i_prompt1", "t2i_prompt2", "negative_prompt"],
        "properties": {
          "image_filename":   { "type": "string" },
          "camera_direction": { "type": "string" },
          "t2i_prompt1":      { "type": "string", "minLength": 60, "maxLength": 150 },
          "t2i_prompt2":      { "type": "string", "minLength": 50, "maxLength": 140 },
          "negative_prompt":  { "type": "string", "minLength": 10, "maxLength": 60 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,

  "_validation_rules": {
    "mode_field":                "mode",
    "VARIATION_mode_count":      6,
    "STORYLINE_mode_count":      "3-4",
    "unique_field_in_VARIATION": "camera_direction"
  }
}
