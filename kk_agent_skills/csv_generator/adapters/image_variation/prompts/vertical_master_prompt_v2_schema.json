{
  "description": "Vertical Chinese prompt generator — Qwen compatible CSV format",
  "_display_field": "t2i_prompt1",
  "_comfyui": {
    "workflows": [
      {
        "name": "QWEN/IMAGE 540x960",
        "workflow_key": "QWEN/Image_QWEN_PA_Studio-540x960-01-dev",
        "field_mappings": {
          "t2i_prompt1": "t2i_prompt1"
        }
      },
      {
        "name": "QWEN/IMAGE 768x13344",
        "workflow_key": "QWEN/Image_QWEN_PA_Studio-768x1344-01-dev",
        "field_mappings": {
          "t2i_prompt1": "t2i_prompt1"
        }
      }
    ]
  },
  "_input_schema": {
    "fields": [
      {
        "name": "images",
        "type": "file",
        "accept": "image/*",
        "multiple": true,
        "required": true,
        "label": "Upload Images"
      }
    ],
    "hide_text_input": true,
    "submit_label": "Generate CSV"
  },
  "_filename_field": "subject",
  "_array_field": "variations",
  "_csv_columns": [
    {
      "header": "image_filename",
      "field": "image_filename"
    },
    {
      "header": "t2i_prompt1",
      "field": "t2i_prompt1"
    },
    {
      "header": "t2i_prompt2",
      "field": "t2i_prompt2"
    },
    {
      "header": "negative_prompt",
      "field": "negative_prompt"
    }
  ],
  "type": "object",
  "required": [
    "mode",
    "subject",
    "variations"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "VARIATION"
      ]
    },
    "subject": {
      "type": "string"
    },
    "variations": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": [
          "image_filename",
          "camera_direction",
          "t2i_prompt1",
          "t2i_prompt2",
          "negative_prompt"
        ],
        "properties": {
          "image_filename": {
            "type": "string"
          },
          "camera_direction": {
            "type": "string"
          },
          "t2i_prompt1": {
            "type": "string"
          },
          "t2i_prompt2": {
            "type": "string"
          },
          "negative_prompt": {
            "type": "string"
          }
        }
      }
    }
  }
}